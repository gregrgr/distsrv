<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PayloadContent</key>
    <dict>
        <key>URL</key>
        <string>https://{{xml .Host}}/udid-callback?app={{xml .AppShortID}}</string>
        <key>DeviceAttributes</key>
        <array>
            <string>UDID</string>
            <string>IMEI</string>
            <string>ICCID</string>
            <string>VERSION</string>
            <string>PRODUCT</string>
            <string>SERIAL</string>
        </array>
    </dict>
    <key>PayloadOrganization</key>
    <string>{{xml .OrgName}}</string>
    <key>PayloadDisplayName</key>
    <string>{{xml .AppName}} UDID 收集</string>
    <key>PayloadVersion</key>
    <integer>1</integer>
    <key>PayloadUUID</key>
    <string>{{xml .PayloadUUID}}</string>
    <key>PayloadIdentifier</key>
    <string>com.{{xml .OrgSlug}}.udid.{{xml .AppShortID}}</string>
    <key>PayloadDescription</key>
    <string>本配置文件用于获取设备 UDID 并发送给分发服务器，便于管理员将本设备加入测试名单。安装后请到「设置 → 通用 → VPN 与设备管理」批准描述文件。</string>
    <key>PayloadType</key>
    <string>Profile Service</string>
</dict>
</plist>
